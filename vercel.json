{
	"rewrites": [
		{
			"source": "/kuma-recipes",
			"destination": "https://kuma-recipes-web.vercel.app/kuma-recipes"
		},
		{
			"source": "/kuma-recipes/:match*",
			"destination": "https://kuma-recipes-web.vercel.app/kuma-recipes/:match*"
		},
		{
			"source": "/shared-recipes/:match*",
			"destination": "https://kuma-recipes-web.vercel.app/kuma-recipes/shared-recipes/:match*"
		}
	],
	"redirects": [
		{
			"source": "/blog",
			"destination": "https://jenny-notes.vercel.app",
			"permanent": false
		},
		{
			"source": "/blog/:slug*",
			"destination": "https://jenny-notes.vercel.app/:slug*",
			"permanent": false
		}
	]
}
